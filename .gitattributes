# Normalize line endings
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.bat text eol=crlf

# Shell scripts and the Gradle wrapper must be LF
gradlew text eol=lf
*.sh text eol=lf

# Binary assets
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.keystore binary
*.jks binary

# Linguist: keep generated/vendored code out of language stats
contracts/** linguist-documentation
docs/** linguist-documentation
