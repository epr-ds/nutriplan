# Local development environment for the NutriPlan backend stack.
# Copy to `.env` and adjust. NEVER commit a real `.env`.

POSTGRES_USER=nutriplan
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nutriplan

MONGO_USER=nutriplan
MONGO_PASSWORD=change-me

# AI service
AI_LLM_API_KEY=

# Identity service
# Leave the JWT keys unset in dev to auto-generate an ephemeral RS256 keypair.
# In stage/prod inject PEM keys from the secrets manager (IDN-803).
# IDENTITY_JWT_PRIVATE_KEY=
# IDENTITY_JWT_PUBLIC_KEY=
# OAuth (IDN-201/202/203): comma-separated provider client IDs accepted as the token `aud`.
# IDENTITY_GOOGLE_CLIENT_IDS=
# IDENTITY_APPLE_CLIENT_IDS=
# IDENTITY_FACEBOOK_CLIENT_IDS=

# Object storage for avatar uploads (IDN-304). The MinIO root creds double as the S3 keys
# the identity service signs presigned URLs with; keep them in sync.
MINIO_USER=nutriplan
MINIO_PASSWORD=change-me-too
AVATAR_BUCKET=avatars
# Endpoint baked into presigned URLs — must be reachable by the mobile client, not minio:9000.
S3_PUBLIC_ENDPOINT=http://localhost:9000
