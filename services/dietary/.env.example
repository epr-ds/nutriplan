# Dietary Planning service configuration (DIETARY_-prefixed env vars)
DIETARY_ENVIRONMENT=development

# MongoDB connection. In dev/compose the mongo service requires the root credentials
# created via MONGO_INITDB_ROOT_* (hence authSource=admin).
DIETARY_MONGO_URL=mongodb://nutriplan:nutriplan@mongo:27017/?authSource=admin
DIETARY_MONGO_DB=dietary

# Access-token verification (DPL-102). Verifies RS256 tokens issued by the Identity service
# against its published JWKS; iss/aud must match what Identity issues.
DIETARY_IDENTITY_JWKS_URL=http://identity:8081/.well-known/jwks.json
DIETARY_JWT_ISSUER=nutriplan-identity
DIETARY_JWT_AUDIENCE=nutriplan
